    {
      "id": "i05",
      "register": "informal",
      "en": "Why didn't you tell me earlier?",
      "expected_markers": ["तिमीले", "तँले"]
    },
    {
      "id": "i06",
      "register": "informal",
      "en": "Let's hang out this evening.",
      "expected_markers": ["हामी", "तिमी"]
    },
    {
      "id": "i07",
      "register": "informal",
      "en": "You look tired, bro.",
      "expected_markers": ["तिमी", "थाकेको"]
